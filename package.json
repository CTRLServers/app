{
  "name": "ctrlservers",
  "version": "1.0.0",
  "description": "CTRLServers Desktop",
  "author": "We Are CTRLServers",
  "main": "electron.cjs",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win portable --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never",
    "build:mac": "electron-builder --mac dmg --publish never"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "xyz.ctrlservers.desktop",
    "productName": "CTRLServers",
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "files": [
      "electron.cjs",
      "preload.js",
      "index.html",
      "styles.css",
      "js/**/*",
      "assets/**/*",
      "src/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/logo.png"
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "ssh2": "^1.17.0",
    "ws": "^8.21.1"
  }
}
